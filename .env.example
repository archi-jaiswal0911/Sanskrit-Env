# Hugging Face router credentials
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alternate names also supported: HUGGINGFACEHUB_API_TOKEN, HUGGINGFACE_API_TOKEN,
# HF_API_TOKEN, HF_API_KEY, HUGGINGFACE_TOKEN

# Sanskrit environment URL (local server or deployed Space)
SANSKRIT_ENV_URL=http://localhost:7860

# HF Router chat completions endpoint
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions

# Model to query via HF Router
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Optional local fallback list (tried in order when HF_MODEL is unavailable)
HF_MODEL_CANDIDATES=Qwen/Qwen2.5-72B-Instruct,meta-llama/Llama-3.3-70B-Instruct,Qwen/Qwen2.5-7B-Instruct,google/gemma-2-9b-it,mistralai/Mistral-7B-Instruct-v0.3,HuggingFaceH4/zephyr-7b-beta
HF_AUTO_MODEL_FALLBACK=1

# Optional: override UI model dropdown list (comma-separated HF model IDs)
# HF_UI_MODELS=meta-llama/Llama-3.3-70B-Instruct,Qwen/Qwen2.5-7B-Instruct

# Generation settings
HF_TEMPERATURE=0.0
HF_MAX_TOKENS=512

# Baseline run controls
EPISODES_PER_TASK=15
RANDOM_SEED=42
RETRY_WAIT=5
HF_REQUEST_TIMEOUT=90
